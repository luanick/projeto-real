<% if (user) { %>
    <!-- Navbar para Usuário Logado -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top shadow-sm">
        <div class="container px-lg-5">
            <a class="navbar-brand fw-bold" href="/books">
                <i class="bi bi-book-half"></i> Biblioteca de Empréstimos
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a href="/books" class="nav-link text-white me-3"><i class="bi bi-collection"></i> Catálogo</a>
                    </li>
                    <li class="nav-item">
                        <a href="/books/new" class="nav-link text-white me-3"><i class="bi bi-plus-square"></i> Anunciar Livro</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle text-white fw-semibold" id="dropdownUser"
                            data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle"></i> <%= user.username %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2"
                            aria-labelledby="dropdownUser">
                            <li><a class="dropdown-item py-2 text-danger" href="/logout"><i
                                        class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
<% } else { %>
    <!-- Navbar para Visitante (Não Logado) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-book-half"></i> Biblioteca de Empréstimos
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-light px-4 me-2" href="/login">Entrar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-warning text-dark px-4 fw-semibold" href="/register">Criar Conta</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
<% } %>