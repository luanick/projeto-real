<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-3">
                <div class="card-header bg-primary text-white text-center py-4 rounded-top-3">
                    <h2 class="fw-bold mb-0"><i class="bi bi-journal-plus"></i> Anunciar Novo Livro</h2>
                    <p class="mb-0 text-white-50 mt-1">Disponibilize um livro de sua coleção para empréstimo</p>
                </div>
                <div class="card-body p-4">
                    <form action="/books" method="POST">
                        <div class="mb-3">
                            <label for="title" class="form-label fw-semibold">Título do Livro</label>
                            <input type="text" class="form-control form-control-lg" id="title" name="title" placeholder="Digite o título do livro" required>
                        </div>
                        <div class="mb-3">
                            <label for="author" class="form-label fw-semibold">Autor(a)</label>
                            <input type="text" class="form-control form-control-lg" id="author" name="author" placeholder="Nome do autor ou autora" required>
                        </div>
                        <div class="mb-3">
                            <label for="description" class="form-label fw-semibold">Descrição / Detalhes</label>
                            <textarea class="form-control" id="description" name="description" rows="4" placeholder="Adicione informações sobre o estado do livro, regras de empréstimo ou um resumo da obra..."></textarea>
                        </div>
                        <div class="d-grid gap-2 mb-3">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold">Confirmar Anúncio</button>
                            <a href="/books" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>