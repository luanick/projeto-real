<div class="container my-5">
    <div class="mb-4">
        <h1 class="fw-bold mb-0">Gerenciar Solicitações</h1>
        <p class="text-muted">Acompanhe as solicitações de empréstimo enviadas e recebidas.</p>
    </div>

    <!-- Abas para navegar entre Solicitações Recebidas e Enviadas -->
    <ul class="nav nav-pills mb-4" id="borrowTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-semibold" id="received-tab" data-bs-toggle="pill" data-bs-target="#received" type="button" role="tab" aria-controls="received" aria-selected="true">
                <i class="bi bi-download me-2"></i>Recebidas 
                <span class="badge bg-light text-primary ms-2">
                    <%= incomingRequests.filter(r => r.status === 'pendente').length %>
                </span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-semibold" id="sent-tab" data-bs-toggle="pill" data-bs-target="#sent" type="button" role="tab" aria-controls="sent" aria-selected="false">
                <i class="bi bi-upload me-2"></i>Enviadas
                <span class="badge bg-light text-primary ms-2">
                    <%= outgoingRequests.filter(r => r.status === 'pendente').length %>
                </span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="borrowTabsContent">
        <!-- ABA DE SOLICITAÇÕES RECEBIDAS -->
        <div class="tab-pane fade show active" id="received" role="tabpanel" aria-labelledby="received-tab">
            <% if (incomingRequests && incomingRequests.length > 0) { %>
                <div class="row g-3">
                    <% incomingRequests.forEach(req => { %>
                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm rounded-3">
                                <div class="card-body p-4 d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <h5 class="fw-bold mb-1 text-truncate" style="max-width: 220px;">
                                                <%= req.book ? req.book.title : 'Livro Indisponível' %>
                                            </h5>
                                            <span class="text-muted small">por <%= req.book ? req.book.author : '-' %></span>
                                        </div>
                                        <div>
                                            <% if (req.status === 'pendente') { %>
                                                <span class="badge bg-warning-subtle text-warning px-2.5 py-1.5 rounded-pill">Pendente</span>
                                            <% } else if (req.status === 'aprovado') { %>
                                                <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill">Emprestado</span>
                                            <% } else if (req.status === 'devolvido') { %>
                                                <span class="badge bg-info-subtle text-info px-2.5 py-1.5 rounded-pill">Devolvido</span>
                                            <% } else { %>
                                                <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill">Recusado</span>
                                            <% } %>
                                        </div>
                                    </div>
                                    
                                    <div class="bg-light p-3 rounded-3 mb-3 mt-auto">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-person-circle text-primary fs-4 me-2"></i>
                                            <div>
                                                <small class="text-muted d-block" style="font-size: 0.75rem;">Solicitante</small>
                                                <span class="fw-semibold text-secondary"><%= req.requester ? req.requester.fullName || req.requester.username : 'Desconhecido' %></span>
                                            </div>
                                        </div>
                                        <small class="text-muted d-block mt-2" style="font-size: 0.75rem;">
                                            <i class="bi bi-clock me-1"></i> Solicitado em: <%= new Date(req.createdAt).toLocaleDateString('pt-BR') %>
                                        </small>
                                    </div>

                                    <% if (req.status === 'pendente') { %>
                                        <div class="d-flex gap-2 mt-2">
                                            <form action="/borrows/<%= req.id %>/approve" method="POST" class="w-50 m-0">
                                                <button type="submit" class="btn btn-success w-100 fw-bold py-2 btn-sm">
                                                    <i class="bi bi-check-lg"></i> Aceitar
                                                </button>
                                            </form>
                                            <form action="/borrows/<%= req.id %>/reject" method="POST" class="w-50 m-0">
                                                <button type="submit" class="btn btn-outline-danger w-100 fw-semibold py-2 btn-sm">
                                                    <i class="bi bi-x-lg"></i> Recusar
                                                </button>
                                            </form>
                                        </div>
                                    <% } else if (req.status === 'aprovado') { %>
                                        <div class="mt-2">
                                            <form action="/borrows/<%= req.id %>/return" method="POST" class="m-0">
                                                <button type="submit" class="btn btn-outline-primary w-100 fw-bold py-2 btn-sm">
                                                    <i class="bi bi-arrow-counterclockwise"></i> Confirmar Devolução
                                                </button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5 shadow-sm rounded bg-white">
                    <i class="bi bi-inbox text-muted" style="font-size: 3.5rem;"></i>
                    <h4 class="fw-bold mt-3 text-secondary">Nenhuma solicitação recebida</h4>
                    <p class="text-muted mb-0">Quando outro usuário solicitar um livro seu, ela aparecerá aqui.</p>
                </div>
            <% } %>
        </div>

        <!-- ABA DE SOLICITAÇÕES ENVIADAS -->
        <div class="tab-pane fade" id="sent" role="tabpanel" aria-labelledby="sent-tab">
            <% if (outgoingRequests && outgoingRequests.length > 0) { %>
                <div class="row g-3">
                    <% outgoingRequests.forEach(req => { %>
                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm rounded-3">
                                <div class="card-body p-4 d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <h5 class="fw-bold mb-1 text-truncate" style="max-width: 220px;">
                                                <%= req.book ? req.book.title : 'Livro Indisponível' %>
                                            </h5>
                                            <span class="text-muted small">por <%= req.book ? req.book.author : '-' %></span>
                                        </div>
                                        <div>
                                            <% if (req.status === 'pendente') { %>
                                                <span class="badge bg-warning-subtle text-warning px-2.5 py-1.5 rounded-pill">Pendente</span>
                                            <% } else if (req.status === 'aprovado') { %>
                                                <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill">Emprestado</span>
                                            <% } else if (req.status === 'devolvido') { %>
                                                <span class="badge bg-primary-subtle text-primary px-2.5 py-1.5 rounded-pill">Devolvido</span>
                                            <% } else { %>
                                                <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill">Recusado</span>
                                            <% } %>
                                        </div>
                                    </div>
                                    
                                    <div class="bg-light p-3 rounded-3 mt-auto mb-3">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-person-workspace text-secondary fs-4 me-2"></i>
                                            <div>
                                                <small class="text-muted d-block" style="font-size: 0.75rem;">Dono do Livro</small>
                                                <span class="fw-semibold text-secondary"><%= req.owner ? req.owner.fullName || req.owner.username : 'Desconhecido' %></span>
                                            </div>
                                        </div>
                                        <small class="text-muted d-block mt-2" style="font-size: 0.75rem;">
                                            <i class="bi bi-clock me-1"></i> Solicitado em: <%= new Date(req.createdAt).toLocaleDateString('pt-BR') %>
                                        </small>
                                    </div>

                                    <% if (req.status === 'aprovado') { %>
                                        <div class="mt-2">
                                            <form action="/borrows/<%= req.id %>/return" method="POST" class="m-0">
                                                <button type="submit" class="btn btn-primary w-100 fw-bold py-2 btn-sm">
                                                    <i class="bi bi-arrow-counterclockwise"></i> Devolver Livro
                                                </button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5 shadow-sm rounded bg-white">
                    <i class="bi bi-send-x text-muted" style="font-size: 3.5rem;"></i>
                    <h4 class="fw-bold mt-3 text-secondary">Nenhuma solicitação enviada</h4>
                    <p class="text-muted mb-0">Explore o catálogo e solicite livros para começar!</p>
                    <a href="/books" class="btn btn-primary fw-bold mt-3">Explorar Catálogo</a>
                </div>
            <% } %>
        </div>
    </div>
</div>
