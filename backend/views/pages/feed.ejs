<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0">Livros Disponíveis</h1>
            <p class="text-muted">Explore as obras anunciadas para empréstimo pelos usuários.</p>
        </div>
        <a href="/books/new" class="btn btn-primary btn-lg fw-bold"><i class="bi bi-plus-lg"></i> Anunciar Livro</a>
    </div>

    <% if (books && books.length > 0) { %>
        <div class="row g-4">
            <% books.forEach(book => { %>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-3">
                        <div class="card-body p-4 d-flex flex-column">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary-subtle text-primary rounded p-3 me-3">
                                    <i class="bi bi-book-half" style="font-size: 1.8rem;"></i>
                                </div>
                                <div>
                                    <h4 class="card-title fw-bold mb-0 text-truncate" style="max-width: 200px;"><%= book.title %></h4>
                                    <h6 class="text-muted mb-0"><%= book.author %></h6>
                                </div>
                            </div>
                            
                            <p class="card-text text-secondary flex-grow-1"><%= book.description || 'Sem descrição disponível.' %></p>
                            
                            <hr class="text-black-50">
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <small class="text-muted">Anunciado por <strong><%= book.owner ? book.owner.username : 'Desconhecido' %></strong></small>
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">Disponível</span>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-5 shadow-sm rounded bg-light">
            <i class="bi bi-journal-bookmark-fill text-muted" style="font-size: 4rem;"></i>
            <h3 class="fw-bold mt-3">Nenhum livro anunciado ainda</h3>
            <p class="text-muted">Seja o primeiro a anunciar um livro para empréstimo na comunidade!</p>
            <a href="/books/new" class="btn btn-primary fw-bold mt-2">Anunciar Meu Primeiro Livro</a>
        </div>
    <% } %>
</div>
